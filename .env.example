# 复制为 .env 并填入你的 key（.env 已被 gitignore，不会提交）

# 模型服务的 API key（OpenAI 兼容）。这里以硅基流动为例。
LLM_API_KEY=sk-xxxxxxxx

# OpenAI 兼容的接口地址。默认硅基流动；换其他家改这里即可：
#   硅基流动:   https://api.siliconflow.cn/v1
#   DeepSeek:   https://api.deepseek.com/v1
#   通义千问:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   Kimi:       https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 模型 ID（注意硅基流动用带前缀的 ID，如 deepseek-ai/DeepSeek-V4-Pro）
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro

# Web 服务可选：设置访问密码，保护接口不被滥用
# APP_PASSWORD=your-pass

# 可选：飞书文档读取（企业自建应用的 App ID / Secret）。
# 应用需开通 docx:document:readonly（读知识库再加 wiki:wiki:readonly），
# 且要读的文档已分享给该应用。
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# 国际版 Lark 改为 https://open.larksuite.com
# FEISHU_BASE=https://open.feishu.cn
